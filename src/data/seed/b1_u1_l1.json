    {
      "id": "b1-u1-l1-c4",
      "lessonId": "b1-u1-l1",
      "type": "grammar_note",
      "title": "Explanation",
      "order": 4,
      "content": {
        "notes": [
          "Y, Y, Ъ, Ь do not appear at the beginning of a word.",
          "In Mongolian, the letters э, ө, ү do not have a soft sign combined with them.",
          "The letter ө does not form a vowel pair with й.",
          "Ы is not used alone, it forms a vowel pair with a, o, у, е, ү.",
          "Ъ and Ь are silent and act as separators before some suffixes.",
          "The letters К, П, Ф, Щ are often used in words of foreign origin.",
          "The letter Н is sometimes pronounced like ng at the end of a word or before х, г."
        ]
      }
    },
