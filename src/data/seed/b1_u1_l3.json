      "title": "Letter notes",
      "order": 3,
      "content": {
        "section": "grammar",
        "notes": [
          "Ъ and Ь are sign letters and do not have their own vowel sound.",
          "Й, Ы, Ъ, and Ь do not usually appear at the beginning of a Mongolian word.",
          "К, П, Ф, and Щ are less common in native Mongolian words."
        ]
      }
